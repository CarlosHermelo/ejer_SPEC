# Entorno
APP_ENV=local

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# CORS (separado por comas, solo necesario si agregás origenes adicionales)
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Supabase
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=your_anon_key_here

# Supabase — conexion directa PostgreSQL (para scripts DDL en prueba/)
# Obtene el valor en: Supabase Dashboard -> Settings -> Database -> Connection String -> URI
SUPABASE_DB_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# WhatsApp / Kapso
KAPSO_API_KEY=
PHONE_NUMBER_ID=
NUMERO_DESTINO=

# OpenTelemetry
OTEL_SERVICE_NAME=ejer-spec-backend
OTEL_TRACES_EXPORTER=none
